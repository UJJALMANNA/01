"""
Pydantic models (request/response schemas) for the application.
"""
from pydantic import BaseModel, EmailStr, Field
from typing import Optional
from datetime import datetime


# ---------- Contact / Query messages ----------

class QueryMessageCreate(BaseModel):
    name: str = Field(..., min_length=2, max_length=100)
    email: EmailStr
    subject: str = Field(..., min_length=2, max_length=150)
    message: str = Field(..., min_length=5, max_length=3000)


class QueryMessageOut(QueryMessageCreate):
    id: str
    created_at: datetime
    status: str = "new"  # new | read | replied


# ---------- Manually-posted news / GATE updates ----------

class NewsPostCreate(BaseModel):
    title: str = Field(..., min_length=3, max_length=200)
    summary: str = Field(..., min_length=3, max_length=2000)
    category: str = Field(..., description="e.g. GATE, Technology, Internship, Exam-Alert")
    link: Optional[str] = None
    author: Optional[str] = "Ujjal Manna"


class NewsPostOut(NewsPostCreate):
    id: str
    created_at: datetime


# ---------- Admin auth (very lightweight) ----------

class AdminLogin(BaseModel):
    username: str
    password: str
