import { useEffect, useState } from 'react'
import { motion } from 'framer-motion'
import { FaExternalLinkAlt, FaSync } from 'react-icons/fa'
import { getLiveNews, getNewsPosts } from '../api/client.js'
import './News.css'

export default function News() {
  const [liveArticles, setLiveArticles] = useState([])
  const [posts, setPosts] = useState([])
  const [loadingLive, setLoadingLive] = useState(true)
  const [loadingPosts, setLoadingPosts] = useState(true)
  const [error, setError] = useState('')

  const loadLiveNews = async (refresh = false) => {
    setLoadingLive(true)
    try {
      const res = await getLiveNews(refresh)
      setLiveArticles(res.data.articles || [])
      setError('')
    } catch (err) {
      setError('Could not load live news right now. The backend may be unreachable or the API key is not configured.')
    } finally {
      setLoadingLive(false)
    }
  }

  const loadPosts = async () => {
    setLoadingPosts(true)
    try {
      const res = await getNewsPosts()
      setPosts(res.data.posts || [])
    } catch (err) {
      // Non-fatal — manual posts are a secondary feature
    } finally {
      setLoadingPosts(false)
    }
  }

  useEffect(() => {
    loadLiveNews()
    loadPosts()
  }, [])

  return (
    <div className="news-page section">
      <div className="container">
        <p className="eyebrow">Stay Updated</p>
        <h1 className="section-heading">Technology News for Engineers</h1>
        <p className="news-page__sub">
          Live updates aggregated from technology news sources, plus GATE and exam
          alerts posted directly by Ujjal.
        </p>

        {/* ---------- Manual GATE / Exam updates ---------- */}
        {!loadingPosts && posts.length > 0 && (
          <div className="news-section">
            <h2 className="news-section__title">GATE &amp; Exam Updates</h2>
            <div className="news-grid">
              {posts.map((post, i) => (
                <motion.div
                  className="card news-card news-card--manual"
                  key={post.id}
                  initial={{ opacity: 0, y: 16 }}
                  whileInView={{ opacity: 1, y: 0 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.4, delay: i * 0.06 }}
                >
                  <span className="tag tag--amber">{post.category}</span>
                  <h3>{post.title}</h3>
                  <p>{post.summary}</p>
                  {post.link && (
                    <a href={post.link} target="_blank" rel="noopener noreferrer" className="news-card__link">
                      Read more <FaExternalLinkAlt size={11} />
                    </a>
                  )}
                </motion.div>
              ))}
            </div>
          </div>
        )}

        {/* ---------- Live tech news ---------- */}
        <div className="news-section">
          <div className="news-section__header">
            <h2 className="news-section__title">Live Technology Feed</h2>
            <button className="btn btn-outline news-refresh" onClick={() => loadLiveNews(true)} disabled={loadingLive}>
              <FaSync className={loadingLive ? 'spin' : ''} size={14} /> Refresh
            </button>
          </div>

          {loadingLive && <p className="news-page__status">Loading latest news…</p>}
          {!loadingLive && error && <p className="news-page__status news-page__status--error">{error}</p>}
          {!loadingLive && !error && liveArticles.length === 0 && (
            <p className="news-page__status">
              No live articles yet — add your NEWS_API_KEY / GNEWS_API_KEY in the backend .env file to enable this feed.
            </p>
          )}

          <div className="news-grid">
            {liveArticles.map((article, i) => (
              <motion.a
                href={article.url}
                target="_blank"
                rel="noopener noreferrer"
                className="card news-card"
                key={`${article.title}-${i}`}
                initial={{ opacity: 0, y: 16 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.4, delay: i * 0.05 }}
              >
                {article.image && <img src={article.image} alt="" className="news-card__img" loading="lazy" />}
                <span className="tag">{article.provider_source_name}</span>
                <h3>{article.title}</h3>
                {article.description && <p>{article.description}</p>}
                <span className="news-card__link">
                  Read full article <FaExternalLinkAlt size={11} />
                </span>
              </motion.a>
            ))}
          </div>
        </div>
      </div>
    </div>
  )
}
